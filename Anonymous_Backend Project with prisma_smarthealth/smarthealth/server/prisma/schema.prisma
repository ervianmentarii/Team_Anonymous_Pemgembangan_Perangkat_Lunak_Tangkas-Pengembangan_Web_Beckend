// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js" // Pastikan menggunakan prisma-client-js
  
}
datasource db {
  provider = "mysql"
  url    = env("DATABASE_URL")
}

enum Specialization {
  KARDIOLOGI_UMUM         @map("Kardiologi Umum")
  KARDIOLOGI_INTERVENSI   @map("Kardiologi Intervensi")
  ELEKTROFISIOLOGI        @map("Elektrofisiologi")
  EKOKARDIOGRAFI          @map("Ekokardiografi")
  KARDIOLOGI_ANAK         @map("Kardiologi Anak")
  BEDAH_KARDIOTORAKS      @map("Bedah Kardiotoraks")
  SPESIALIS_GAGAL_JANTUNG @map("Spesialis Gagal Jantung")
}

enum Hari {
  Senin  @map("Senin")
  Selasa @map("Selasa")
  Rabu   @map("Rabu")
  Kamis  @map("Kamis")
  Jumat  @map("Jumat")
  Sabtu  @map("Sabtu")
  Minggu @map("Minggu")
}

enum JenisKelamin {
  Laki_laki @map("Laki-laki")
  Perempuan @map("Perempuan")
}

enum Status {
  Terjadwal  @map("Terjadwal")
  Selesai    @map("Selesai")
  Dibatalkan @map("Dibatalkan")
}

enum JenisFile {
  KTP
  BPJS
  SELFIE_BPJS
  LISENSI
}

enum Role {
  ADMIN
  DOKTER
  PASIEN
}

enum StatusLog{
  ONPROGRESS
  REJECTED
  SUCCESS 
}

model InfDokter {
  id              Int               @id @default(autoincrement())
  namaLengkap     String            @map("nama_lengkap") @db.VarChar(255)
  password        String
  email           String            @unique
  subSpesialisasi Specialization    @map("sub_spesialisasi")
  nomorTelepon    String            @map("nomor_telepon") @db.VarChar(50)
  mulaiPraktik    DateTime          @map("mulai_praktik") @db.Date
  jadwal          InfJadwalDokter[]
  janjiTemu       InfJanjiTemu[]
  files           FileDokter[]
  auth            AuthUser?
  auditLog      AuditLog[]

  @@map("inf_dokter")
}

model InfJadwalDokter {
  id                Int            @id @default(autoincrement())
  id_dokter         Int
  hari              Hari           @map("hari")
  jam_buka          DateTime       @map("jam_buka") @db.Time
  jam_tutup         DateTime       @map("jam_tutup") @db.Time
  durasi_slot_menit Int            @map("durasi_slot_menit")

  dokter            InfDokter      @relation(fields: [id_dokter], references: [id], onDelete: Cascade)
  janjiTemu         InfJanjiTemu[]

  @@map("inf_jadwal_dokter")
}

model InfJanjiTemu {
  id          Int       @id @default(autoincrement())
  id_dokter   Int       @map("id_dokter")
  id_pasien   Int       @map("id_pasien")
  id_jadwal   Int       @map("id_jadwal")
  waktu_janji DateTime  @map("waktu_janji") @db.DateTime
  status      Status    @map("status")
  catatan     String?   @map("catatan") @db.Text

  dokter      InfDokter       @relation(fields: [id_dokter], references: [id])
  pasien      InfPasien       @relation(fields: [id_pasien], references: [id])
  jadwal      InfJadwalDokter @relation(fields: [id_jadwal], references: [id])

  @@map("inf_janji_temu")
}

model InfPasien {
  id            Int      @id @default(autoincrement())

  namaLengkap   String   @map("nama_lengkap")
  password      String
  email         String   @unique
  nik           String   @unique
  jenisKelamin  String   @map("jenis_kelamin")
  tanggalLahir  DateTime @map("tanggal_lahir") @db.Date
  alamat        String?

  nomorTelepon  String?  @map("nomor_telepon")

  janjiTemu     InfJanjiTemu[]
  files         FilePasien[]
  auth          AuthUser?
  auditLog      AuditLog[]

  @@map("inf_pasien")
}

model FilePasien {
  id          Int      @id @default(autoincrement())

  pasienId    Int      @map("pasienId")
  jenisFile   JenisFile @map("jenisFile")

  filename    String   @map("filename")
  filepath    String   @map("filepath")
  mimetype    String   @map("mimetype")
  size        Int      @map("size")

  createdAt   DateTime @default(now()) @map("createdAt") @db.Timestamp

  pasien      InfPasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  @@map("FilePasien")
}

model FileDokter {
  id          Int      @id @default(autoincrement())

  dokterId    Int      @map("dokterId")
  jenisFile   JenisFile @map("jenisFile")
  
  filename    String   @map("filename")
  filepath    String   @map("filepath")
  mimetype    String   @map("mimetype")
  size        Int      @map("size")

  dokter      InfDokter @relation(fields: [dokterId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("createdAt") @db.Timestamp

  @@map("fileDocter")
}

model AuthUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role

  dokterId  Int?     @unique
  pasienId  Int?     @unique

  dokter    InfDokter? @relation(fields: [dokterId], references: [id])
  pasien    InfPasien? @relation(fields: [pasienId], references: [id])

  createdAt DateTime @default(now())

  @@map("auth_user")
}

model AuditLog{
  id Int @id @default(autoincrement())

  dokterId  Int?     @unique @map("dokter_id")
  pasienId  Int?     @unique @map("pasien_id")

  status StatusLog
  catatan     String?   @map("catatan") @db.Text
  createdAdd DateTime   @default(now()) @map("created_at")
  dokter    InfDokter? @relation(fields: [dokterId], references: [id])
  pasien    InfPasien? @relation(fields: [pasienId], references: [id])

@@map("audit_log")
}